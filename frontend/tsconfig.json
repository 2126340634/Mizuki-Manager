{
	"compilerOptions": {
		"types": ["react", "react-dom", "sass-loader"],
		"jsx": "react",
		"target": "esnext",
		"module": "esnext",
		"lib": ["DOM", "DOM.Iterable", "ESNext"],
		"allowJs": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"moduleResolution": "bundler"
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "build", "public"]
}
